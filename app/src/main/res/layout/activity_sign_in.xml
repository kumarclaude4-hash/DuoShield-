<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_background"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Shield logo -->
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="64dp"
                android:src="@drawable/ic_shield"
                android:contentDescription="DuoShield logo"
                app:tint="@color/ds_accent" />

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/app_name"
                android:textColor="@color/ds_text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:fontFamily="sans-serif-medium" />

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/app_tagline"
                android:textColor="@color/ds_text_secondary"
                android:textSize="14sp" />

            <!-- Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                app:cardBackgroundColor="@color/ds_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ds_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/Widget.DuoShield.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_email"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/ds_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/ds_text_primary"
                            android:imeOptions="actionNext" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/Widget.DuoShield.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_password"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/ds_text_secondary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/ds_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/ds_text_primary"
                            android:imeOptions="actionDone" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot password -->
                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="@string/forgot_password"
                        android:textColor="@color/ds_accent"
                        android:textSize="13sp"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Sign In button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/sign_in"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        app:backgroundTint="@color/ds_accent"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/ds_accent_ripple" />

                    <!-- Progress -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:trackColor="@color/ds_divider"
                        app:indicatorColor="@color/ds_accent"
                        app:trackCornerRadius="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sign up prompt -->
            <TextView
                android:id="@+id/tvSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/no_account"
                android:textColor="@color/ds_text_secondary"
                android:textSize="14sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Lock icon at bottom -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/ds_text_tertiary"
                    android:contentDescription="secure" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Messages are end-to-end encrypted"
                    android:textColor="@color/ds_text_tertiary"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
