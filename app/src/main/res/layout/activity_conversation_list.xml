<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- ── Custom header bar ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_shield"
            android:scaleType="fitCenter"
            android:tint="@color/accent"
            android:contentDescription="DuoShield"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DuoShield"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/btn_search_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_search"
            android:padding="8dp"
            android:tint="@color/text_secondary"
            android:contentDescription="Search"/>

        <ImageView
            android:id="@+id/btn_menu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:padding="8dp"
            android:tint="@color/text_secondary"
            android:contentDescription="Menu"/>
    </LinearLayout>

    <!-- ── Inline search bar (hidden until search icon tapped) ────── -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:tint="@color/text_hint"
            android:layout_marginEnd="8dp"
            android:contentDescription="Search"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Search conversations…"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@null"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

        <ImageView
            android:id="@+id/btn_close_search"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_hint"
            android:padding="6dp"
            android:contentDescription="Close search"/>
    </LinearLayout>

    <!-- Offline banner -->
    <TextView
        android:id="@+id/tv_offline_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/error_red"
        android:text="No internet connection"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="4dp"
        android:visibility="gone"/>

    <!-- Message list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerConversations"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="72dp"/>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_shield"
                android:tint="#33FFFFFF"
                android:contentDescription="No chats"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No conversations yet"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pair with a contact to start chatting"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
