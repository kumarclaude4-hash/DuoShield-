<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ds_background"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/ds_toolbar"
        app:title="Messages"
        app:titleTextColor="@color/ds_text_primary"
        app:menu="@menu/conversation_list_menu"
        app:navigationIconTint="@color/ds_text_primary" />

    <!-- Offline banner -->
    <TextView
        android:id="@+id/bannerOffline"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="@string/no_network"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:background="@color/ds_warning"
        android:visibility="gone" />

    <!-- Search bar — plain EditText, Material 1.x compatible -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_search_bar"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:hint="@string/search_conversations"
        android:textColor="@color/ds_text_primary"
        android:textColorHint="@color/ds_text_tertiary"
        android:textSize="14sp"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:singleLine="true"
        android:visibility="gone" />

    <!-- Conversation list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerConversations"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <!-- Empty state — id kept as tvEmpty for Java compat -->
        <LinearLayout
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_shield"
                android:alpha="0.2"
                app:tint="@color/ds_text_secondary"
                android:contentDescription="no conversations" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/no_conversations"
                android:textColor="@color/ds_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/no_conversations_sub"
                android:textColor="@color/ds_text_secondary"
                android:textSize="14sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- FAB: New chat -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNewChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="@string/new_chat"
            app:backgroundTint="@color/ds_accent"
            app:tint="#FFFFFF"
            app:rippleColor="@color/ds_accent_ripple" />

    </FrameLayout>

</LinearLayout>
