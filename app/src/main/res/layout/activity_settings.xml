<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="Settings"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ══ Section: Appearance ══════════════════════════════════ -->
            <TextView
                android:text="APPEARANCE"
                style="@style/SectionHeader" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDarkMode"
                android:text="Dark mode"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <View style="@style/Divider" />

            <!-- ══ Section: Notifications ═══════════════════════════════ -->
            <TextView
                android:text="NOTIFICATIONS"
                style="@style/SectionHeader" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchNotifications"
                android:text="Enable push notifications"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <View style="@style/Divider" />

            <!-- ══ Section: App PIN ═════════════════════════════════════ -->
            <TextView
                android:text="APP PIN"
                style="@style/SectionHeader" />

            <TextView
                android:id="@+id/tvPinStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etNewPin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="New PIN (4–6 digits)"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etConfirmPin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Confirm PIN"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetPin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Set PIN"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearPin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clear PIN"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/error_red" />
            </LinearLayout>

            <View style="@style/Divider" />

            <!-- ══ Section: Biometric ════════════════════════════════════ -->
            <TextView
                android:text="BIOMETRIC LOCK"
                style="@style/SectionHeader" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBiometric"
                android:text="Require fingerprint / face to unlock"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <TextView
                android:text="Uses your device biometric only — never the phone's PIN/password. Falls back to the app PIN above."
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <View style="@style/Divider" />

            <!-- ══ Section: Duress PIN ══════════════════════════════════ -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:text="DURESS PIN"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/error_red"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:text="Enter this at the lock screen instead of your app PIN to silently wipe all data. Must differ from your app PIN."
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etDuressPin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Duress PIN (4–6 digits)"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetDuressPin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Duress PIN"
                    android:backgroundTint="@color/error_red" />
            </LinearLayout>

            <View style="@style/Divider" />

            <!-- ══ Section: Disappearing Messages ══════════════════════ -->
            <TextView
                android:text="DISAPPEARING MESSAGES"
                style="@style/SectionHeader" />

            <TextView
                android:text="When enabled, new messages are automatically deleted from both devices after the chosen time. Applies to messages sent after this setting is changed."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:text="Timer: "
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDisappearing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDisappearSub"
                android:text="New messages will not automatically disappear."
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <View style="@style/Divider" />

            <!-- ══ Section: Auto-Delete ══════════════════════════════════ -->
            <TextView
                android:text="AUTO-DELETE"
                style="@style/SectionHeader" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchSelfDestruct"
                android:text="Auto-delete messages"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutMinutes"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <TextView
                    android:text="Delete after "
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <EditText
                    android:id="@+id/editTtlMinutes"
                    android:inputType="number"
                    android:text="60"
                    android:textColor="@color/text_primary"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:maxLength="5"
                    android:gravity="center" />

                <TextView
                    android:text=" minutes"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/textTtlHint"
                android:text="Range: 5 – 10 080 minutes (7 days)"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone" />

            <View style="@style/Divider" />

            <!-- ══ Section: Danger Zone ══════════════════════════════════ -->
            <TextView
                android:text="DANGER ZONE"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textColor="@color/error_red"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnpair"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unpair Device"
                android:backgroundTint="@color/error_red"
                android:layout_marginBottom="6dp" />

            <TextView
                android:text="Clears all pairing data and local messages. Cannot be undone."
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
