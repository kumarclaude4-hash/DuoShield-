<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/ds_background"
    android:fitsSystemWindows="true">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar" android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/Widget.DuoShield.Toolbar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/pair_device"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:scrollbars="none">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">
            <ImageView android:layout_width="64dp" android:layout_height="64dp"
                android:src="@drawable/ic_lock" app:tint="@color/ds_accent"
                android:contentDescription="pair"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="12dp" android:gravity="center"
                android:text="@string/pair_subtitle"
                android:textColor="@color/ds_text_secondary" android:textSize="14sp"/>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/ds_surface" app:cardCornerRadius="12dp"
                app:cardElevation="0dp" app:strokeColor="@color/ds_divider" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/your_code"
                        android:textColor="@color/ds_accent" android:textSize="11sp"
                        android:textAllCaps="true" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/tvMyCode"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/ds_text_primary" android:textSize="13sp"
                        android:fontFamily="monospace" android:lineSpacingMultiplier="1.5"
                        android:background="@color/ds_surface_2"
                        android:padding="10dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyCode"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:layout_marginTop="12dp" android:text="@string/copy_code"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/ds_accent" app:cornerRadius="10dp"
                        android:textColor="@color/ds_accent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DuoShield.TextInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:hint="@string/hint_partner_code">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPartnerCode"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="text" android:textColor="@color/ds_text_primary"
                    android:fontFamily="monospace"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPair"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="20dp" android:text="@string/pair"
                app:backgroundTint="@color/ds_accent" app:cornerRadius="12dp"
                android:textStyle="bold"/>
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressPairing"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:visibility="gone"
                app:indicatorColor="@color/ds_accent" app:trackColor="@color/ds_divider"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
