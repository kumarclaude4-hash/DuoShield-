<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Pin indicator row -->
    <LinearLayout
        android:id="@+id/pinIndicatorRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingBottom="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/pinIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📌 Pinned"
            android:textSize="10sp"
            android:textColor="@color/accent"/>
    </LinearLayout>

    <!-- Sender label (partner name for their messages only) -->
    <TextView
        android:id="@+id/senderLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/accent"
        android:paddingStart="4dp"
        android:paddingBottom="2dp"
        android:visibility="gone"/>

    <!-- Bubble wrapper — gravity set programmatically -->
    <FrameLayout
        android:id="@+id/bubbleWrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/messageBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:maxWidth="280dp">

            <!-- Reply preview -->
            <LinearLayout
                android:id="@+id/replyPreviewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#22000000"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/replyPreviewText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Text message -->
            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#FFFFFFFF"
                android:lineSpacingExtra="2dp"
                android:visibility="gone"/>

            <!-- Image message -->
            <ImageView
                android:id="@+id/messageImage"
                android:layout_width="220dp"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:contentDescription="Image"
                android:visibility="gone"/>

            <!-- Video message -->
            <FrameLayout
                android:id="@+id/videoContainer"
                android:layout_width="220dp"
                android:layout_height="160dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/videoThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#FF1A1A1A"
                    android:contentDescription="Video"/>

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:background="#88000000">

                    <ImageView
                        android:id="@+id/videoPlayBtn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_video"
                        android:tint="#FFFFFFFF"
                        android:contentDescription="Play video"/>
                </FrameLayout>
            </FrameLayout>

            <!-- Contact card -->
            <LinearLayout
                android:id="@+id/contactCardContainer"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person"
                    android:tint="#AAFFFFFF"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Contact"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/cardName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/cardUid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#AAFFFFFF"/>

                    <Button
                        android:id="@+id/cardCopyBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="Copy ID"
                        android:textSize="10sp"
                        android:textColor="@color/accent"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Voice note player -->
            <LinearLayout
                android:id="@+id/voiceNoteContainer"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/voicePlayPauseBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_play_video"
                    android:tint="#FFFFFFFF"
                    android:padding="4dp"
                    android:contentDescription="Play voice note"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <com.duoshield.app.ui.WaveformView
                        android:id="@+id/voiceWaveform"
                        android:layout_width="match_parent"
                        android:layout_height="28dp"/>

                    <TextView
                        android:id="@+id/voiceDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="10sp"
                        android:textColor="#AAFFFFFF"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Link preview card (shown for text messages containing a URL) -->
            <LinearLayout
                android:id="@+id/linkPreviewCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#18FFFFFF"
                android:layout_marginTop="6dp"
                android:visibility="gone">

                <!-- OG image thumbnail -->
                <ImageView
                    android:id="@+id/linkPreviewImage"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Link preview image"
                    android:visibility="gone"/>

                <!-- Accent bar + domain + title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left accent bar -->
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:id="@+id/linkPreviewDomain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/accent"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/linkPreviewTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#EEFFFFFF"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Meta row: edited + timestamp + tick -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="end"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/editedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="edited"
                    android:textSize="10sp"
                    android:textColor="#88FFFFFF"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/messageTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#AAFFFFFF"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:id="@+id/tickIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:visibility="gone"
                    android:contentDescription="Status"/>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- Reaction badge (below bubble) -->
    <TextView
        android:id="@+id/reactionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:paddingStart="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"/>

</LinearLayout>
