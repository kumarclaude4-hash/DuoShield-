<?xml version="1.0" encoding="utf-8"?>
<!--
  Universal message item — driven by view type in MessageAdapter.
  All IDs match the current MessageAdapter implementation.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Date header (Today / Yesterday / Mon 9 Jun) -->
    <TextView
        android:id="@+id/tvDateHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_date_header"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textColor="@color/ds_text_secondary"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Sender label above bubble (#14) -->
    <TextView
        android:id="@+id/senderLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="2dp"
        android:textColor="@color/ds_text_secondary"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Bubble row — gravity toggled programmatically (start=theirs, end=mine) -->
    <LinearLayout
        android:id="@+id/messageBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_theirs"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_gravity="start">

        <!-- Reply preview (inside bubble) -->
        <LinearLayout
            android:id="@+id/replyPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_reply_preview"
            android:padding="6dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:minHeight="24dp"
                android:background="@color/ds_reply_bar"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvReplyPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_secondary"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Contact card (#12) -->
        <LinearLayout
            android:id="@+id/contactCardContainer"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_reply_preview"
            android:padding="8dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/cardName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardUid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <Button
                android:id="@+id/cardCopyBtn"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Copy ID"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Image media -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/messageImage"
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            app:shapeAppearance="@style/ShapeMedium"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            android:contentDescription="image" />

        <!-- Video container -->
        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:visibility="gone"
            android:layout_marginBottom="4dp">

            <VideoView
                android:id="@+id/videoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_video"
                app:tint="@color/ds_text_on_accent"
                android:background="@drawable/bg_play_button"
                android:contentDescription="play" />

        </FrameLayout>

        <!-- Voice note -->
        <LinearLayout
            android:id="@+id/voiceContainer"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btnVoicePlay"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_play_video"
                app:tint="@color/ds_accent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="play voice" />

            <SeekBar
                android:id="@+id/voiceSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:thumbTint="@color/ds_accent"
                android:progressTint="@color/ds_accent"
                android:progressBackgroundTint="@color/ds_divider" />

            <TextView
                android:id="@+id/tvVoiceDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Message text -->
        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ds_text_primary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.2"
            android:autoLink="web|email"
            android:linksClickable="true"
            android:visibility="gone" />

        <!-- Edited label + timestamp + tick row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="end"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/editedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edited"
                android:textColor="@color/ds_text_tertiary"
                android:textSize="10sp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/pinIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_pin"
                app:tint="@color/ds_pin"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                android:contentDescription="pinned" />

            <TextView
                android:id="@+id/messageTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ds_text_timestamp"
                android:textSize="10sp"
                android:layout_marginEnd="3dp" />

            <ImageView
                android:id="@+id/tickIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_done"
                app:tint="@color/ds_tick_pending"
                android:contentDescription="status" />

        </LinearLayout>

    </LinearLayout>

    <!-- Reaction pill (below bubble) -->
    <TextView
        android:id="@+id/reactionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_reaction"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_marginTop="2dp"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>
