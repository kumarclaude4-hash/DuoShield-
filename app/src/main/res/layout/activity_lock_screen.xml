<?xml version="1.0" encoding="utf-8"?>
<!--
  IDs kept exactly as LockScreenActivity.java expects:
    etPin, tvError, btnUnlock, btnBiometric
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/ds_background"
    android:padding="32dp">

    <!-- Shield icon -->
    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_shield"
        app:tint="@color/ds_accent"
        android:contentDescription="DuoShield" />

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/app_name"
        android:textColor="@color/ds_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Instruction -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="@string/enter_pin"
        android:textColor="@color/ds_text_secondary"
        android:textSize="14sp" />

    <!--
        PIN EditText — the Java code attaches TextWatcher here,
        runs shake animation on wrong PIN, and reads text for validation.
        Styled with large dot characters; system numeric keyboard appears.
    -->
    <EditText
        android:id="@+id/etPin"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_field"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:textSize="24sp"
        android:textColor="@color/ds_text_primary"
        android:letterSpacing="0.3"
        android:imeOptions="actionDone" />

    <!-- Error message -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/ds_danger"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="invisible" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Biometric button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBiometric"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/use_biometric"
        android:drawableStart="@drawable/ic_fingerprint"
        android:drawablePadding="10dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="@color/ds_divider"
        app:cornerRadius="12dp"
        android:textColor="@color/ds_accent"
        app:iconTint="@color/ds_accent"
        android:visibility="gone" />

    <!-- Unlock button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnlock"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:text="@string/unlock"
        app:backgroundTint="@color/ds_accent"
        app:cornerRadius="12dp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>
