<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════
         Base DuoShield Theme — Signal × Telegram
    ═══════════════════════════════════════════ -->
    <style name="Theme.DuoShield" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colours -->
        <item name="colorPrimary">@color/ds_accent</item>
        <item name="colorPrimaryVariant">@color/ds_accent_dim</item>
        <item name="colorOnPrimary">@color/ds_text_on_accent</item>
        <item name="colorSecondary">@color/ds_accent</item>
        <item name="colorSecondaryVariant">@color/ds_accent_dim</item>
        <item name="colorOnSecondary">@color/ds_text_on_accent</item>
        <item name="colorSurface">@color/ds_surface</item>
        <item name="colorOnSurface">@color/ds_text_primary</item>
        <item name="colorError">@color/ds_danger</item>
        <item name="colorOnError">@color/ds_text_on_accent</item>
        <!-- android:colorBackground covers the window/view background -->
        <item name="android:colorBackground">@color/ds_background</item>
        <item name="android:windowBackground">@color/ds_background</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/ds_text_primary</item>
        <item name="android:textColorSecondary">@color/ds_text_secondary</item>
        <item name="android:textColorHint">@color/ds_text_tertiary</item>

        <!-- Ripple -->
        <item name="rippleColor">@color/ds_accent_ripple</item>
        <item name="colorControlHighlight">@color/ds_accent_ripple</item>

        <!-- Navigation / Status bar -->
        <item name="android:navigationBarColor">@color/ds_background</item>
        <item name="android:statusBarColor">@color/ds_toolbar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">false</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Window transitions -->
        <item name="android:windowAnimationStyle">@style/WindowAnim.DuoShield</item>
        <item name="android:windowContentTransitions">true</item>

        <!-- TextInputLayout defaults -->
        <item name="textInputStyle">@style/Widget.DuoShield.TextInput</item>

        <!-- AlertDialog -->
        <item name="alertDialogTheme">@style/Theme.DuoShield.Dialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.DuoShield.Dialog</item>

        <!-- Bottom Sheet -->
        <item name="bottomSheetDialogTheme">@style/Theme.DuoShield.BottomSheet</item>

        <!-- Switch (Material3-style teal) -->
        <item name="switchStyle">@style/Widget.DuoShield.Switch</item>
    </style>

    <!-- Full-screen variant (media viewer, image viewer) -->
    <style name="Theme.DuoShield.FullScreen" parent="Theme.DuoShield">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:ignore="NewApi">shortEdges</item>
    </style>

    <!-- Lock screen — no animation, secure -->
    <style name="Theme.DuoShield.Lock" parent="Theme.DuoShield">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:statusBarColor">@color/ds_background</item>
    </style>

    <!-- ── Shapes ── -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearanceOverlay.CircleAvatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ── Window animations ── -->
    <style name="WindowAnim.DuoShield" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- ── TextInput ── -->
    <style name="Widget.DuoShield.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/ds_input_bg</item>
        <item name="boxStrokeColor">@color/ds_input_border_focus</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/ds_text_secondary</item>
        <item name="android:textColorHint">@color/ds_text_tertiary</item>
    </style>

    <!-- ── Dialogs ── -->
    <style name="Theme.DuoShield.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/ds_surface_2</item>
        <item name="colorOnSurface">@color/ds_text_primary</item>
        <item name="colorPrimary">@color/ds_accent</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <!-- ── Bottom Sheet ── -->
    <style name="Theme.DuoShield.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.DuoShield.BottomSheet</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>
    <style name="Widget.DuoShield.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@color/ds_surface_2</item>
        <item name="shapeAppearance">@style/ShapeLarge</item>
    </style>

    <!-- ── Switch ── -->
    <style name="Widget.DuoShield.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="colorPrimary">@color/ds_accent</item>
        <item name="colorControlNormal">@color/ds_text_tertiary</item>
    </style>

    <!-- ── Settings section headers / dividers ── -->
    <style name="SectionHeader">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/ds_accent</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/ds_divider</item>
        <item name="android:layout_marginStart">16dp</item>
    </style>

    <!-- ── Toolbar ── -->
    <style name="Widget.DuoShield.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/ds_toolbar</item>
        <item name="titleTextColor">@color/ds_text_primary</item>
        <item name="subtitleTextColor">@color/ds_text_secondary</item>
        <item name="navigationIconTint">@color/ds_text_primary</item>
    </style>

    <!-- ── FAB ── -->
    <style name="Widget.DuoShield.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/ds_accent</item>
        <item name="tint">@color/ds_text_on_accent</item>
        <item name="rippleColor">@color/ds_accent_ripple</item>
        <item name="elevation">6dp</item>
    </style>

</resources>
