rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone authenticated can read (needed for ECDH key exchange,
    // partner display info, FCM token delivery). Only the owner can write.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Chats (current schema): only participants can read/write
    match /chats/{chatId} {
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Legacy pairing rooms (kept for backwards compatibility)
    match /rooms/{code} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                    && resource.data.status == "waiting"
                    && resource.data.joinerUid == "";
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.creatorUid
                        || request.auth.uid == resource.data.joinerUid);
    }

    // Legacy conversations (kept for backwards compatibility)
    match /conversations/{convId} {
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    // User ID → Firebase UID mapping (used for pairing by DS-XXXXXXXX)
    // Read restricted to authenticated users only — open read leaks all user IDs.
    match /identities/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Passphrase recovery blob: AES-GCM({email, passphrase}, PBKDF2(recoveryCode)).
    // Even though the blob is encrypted, restricting to the owner prevents offline
    // brute-force attacks against the full corpus.
    match /recovery/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
